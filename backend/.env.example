# Runtime
ENVIRONMENT=development
SECRET_KEY=change-me-before-public-deployment
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM provider: openai | deepseek | qwen
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace-with-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# OpenAI alternative
# LLM_PROVIDER=openai
# OPENAI_API_KEY=replace-with-your-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.6-terra

# Qwen alternative
# LLM_PROVIDER=qwen
# QWEN_API_KEY=replace-with-your-key
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen3.7-plus

# Local defaults: SQLite + in-memory verification codes.
# Override DATABASE_URL for PostgreSQL in hosted deployments.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dreamcoder?client_encoding=utf8
# PROJECTS_DIR=./static/projects
REDIS_ENABLED=false
REDIS_REQUIRED=false

# console auto-fills a development verification code in the web UI.
# Hosted deployments should use AUTH_DELIVERY_MODE=external.
AUTH_DELIVERY_MODE=console

# Optional external email delivery
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=465
# SMTP_SENDER=you@example.com
# SMTP_PASSWORD=replace-with-app-password

# Optional external SMS delivery
# ALIBABA_CLOUD_ACCESS_KEY_ID=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# ALIBABA_SMS_SIGN_NAME=
# ALIBABA_SMS_TEMPLATE_CODE=
